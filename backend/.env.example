# Database
MONGODB_URI=mongodb://localhost:27017/indian-stock-basket
DB_NAME=indian-stock-basket

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# Email Configuration (Using Gmail)
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_FROM=noreply@indian-stock-basket.com

# Stock Data API (Optional - for enhanced data)
ALPHA_VANTAGE_KEY=your_api_key_here
IEX_CLOUD_KEY=your_api_key_here

# Rebalancing
REBALANCE_INTERVAL=30
REBALANCE_TIME=09:30

# Frontend URL
FRONTEND_URL=http://localhost:3000
